import pandas as pd 


import numpy as np 


import matplotlib.pyplot as plt
import seaborn as sns


df = pd.read_csv('data.csv')
df





sns.lineplot(x='Month',y = 'PewDiePie (Millions)' , data = df,color = 'black',linestyle='--',label = 'PewDiepie')
sns.lineplot(x = 'Month',y = 'T-Series (Millions)',data = df,color = 'green',linestyle=':',label='T-Series')

plt.style.use('dark_background')
plt.xticks(rotation = 45)
plt.xlabel('Months between [2018-2019]')
plt.ylabel('Pewdiepie Vs T-Series')
plt.tight_layout()
plt.grid(True)
plt.legend()



